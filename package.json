{
  "name": "nexus-local-workflow-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test": "NEXUS_USE_OLLAMA_EMBEDDINGS=0 NEXUS_BROWSER_VISIBLE=0 node --test tests/suite.js",
    "model:serve": "ollama serve",
    "model:pull": "ollama pull qwen2.5-coder:7b && ollama pull nomic-embed-text",
    "memory:pull": "docker pull qdrant/qdrant",
    "memory:start": "docker compose up -d qdrant",
    "memory:stop": "docker compose stop qdrant"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1"
  }
}
